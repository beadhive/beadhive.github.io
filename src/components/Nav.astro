---
interface Props {
  active?: string;
}
const { active } = Astro.props;

const links = [
  { href: '/', label: 'Home', key: 'home' },
  { href: '/beads/', label: 'Beads', key: 'beads' },
  { href: '/process/', label: 'Process', key: 'process' },
  { href: '/roles/', label: 'Roles', key: 'roles' },
  { href: '/fleet/', label: 'Fleet', key: 'fleet' },
];
---
<nav class="topnav">
  <div class="breakout topnav-inner">
    <a class="brand display" href="/" aria-label="Beadhive home">
      <svg width="22" height="24" viewBox="0 0 22 24" aria-hidden="true">
        <polygon points="11,1 20.5,6.5 20.5,17.5 11,23 1.5,17.5 1.5,6.5"
                 fill="none" stroke="currentColor" stroke-width="2"/>
      </svg>
      beadhive
    </a>
    <div class="navlinks display">
      {links.map((l) => (
        <a href={l.href} aria-current={active === l.key ? 'page' : undefined}>{l.label}</a>
      ))}
    </div>
    <button class="themetoggle" type="button" aria-label="Toggle color theme" title="Toggle theme">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
           stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="4.2" class="tt-sun-core"></circle>
        <g class="tt-sun-rays">
          <line x1="12" y1="1.8" x2="12" y2="4.4"></line>
          <line x1="12" y1="19.6" x2="12" y2="22.2"></line>
          <line x1="1.8" y1="12" x2="4.4" y2="12"></line>
          <line x1="19.6" y1="12" x2="22.2" y2="12"></line>
          <line x1="4.6" y1="4.6" x2="6.4" y2="6.4"></line>
          <line x1="17.6" y1="17.6" x2="19.4" y2="19.4"></line>
          <line x1="4.6" y1="19.4" x2="6.4" y2="17.6"></line>
          <line x1="17.6" y1="6.4" x2="19.4" y2="4.6"></line>
        </g>
        <path class="tt-moon" d="M20 14.5A8 8 0 0 1 9.5 4 7 7 0 1 0 20 14.5z"></path>
      </svg>
    </button>
  </div>
</nav>
