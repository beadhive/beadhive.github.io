---
interface Props {
  active?: string;
}
const { active } = Astro.props;

const links = [
  { href: '/', label: 'Home', key: 'home' },
  { href: '/beads/', label: 'Beads', key: 'beads' },
  { href: '/process/', label: 'Process', key: 'process' },
  { href: '/roles/', label: 'Roles', key: 'roles' },
  { href: '/fleet/', label: 'Fleet', key: 'fleet' },
];
---
<nav class="topnav">
  <div class="breakout topnav-inner">
    <a class="brand display" href="/" aria-label="Beadhive home">
      <svg width="22" height="24" viewBox="0 0 22 24" aria-hidden="true">
        <polygon points="11,1 20.5,6.5 20.5,17.5 11,23 1.5,17.5 1.5,6.5"
                 fill="none" stroke="currentColor" stroke-width="2"/>
      </svg>
      beadhive
    </a>
    <div class="navlinks display">
      {links.map((l) => (
        <a href={l.href} aria-current={active === l.key ? 'page' : undefined}>{l.label}</a>
      ))}
    </div>
    <a class="ghlink display" href="https://github.com/beadhive/beadhive"
       aria-label="Beadhive on GitHub" title="beadhive/beadhive on GitHub">
      <svg width="17" height="17" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
        <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
      </svg>
      <span class="ghstars" hidden></span>
    </a>
    <button class="themetoggle" type="button" aria-label="Toggle color theme" title="Toggle theme">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
           stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="4.2" class="tt-sun-core"></circle>
        <g class="tt-sun-rays">
          <line x1="12" y1="1.8" x2="12" y2="4.4"></line>
          <line x1="12" y1="19.6" x2="12" y2="22.2"></line>
          <line x1="1.8" y1="12" x2="4.4" y2="12"></line>
          <line x1="19.6" y1="12" x2="22.2" y2="12"></line>
          <line x1="4.6" y1="4.6" x2="6.4" y2="6.4"></line>
          <line x1="17.6" y1="17.6" x2="19.4" y2="19.4"></line>
          <line x1="4.6" y1="19.4" x2="6.4" y2="17.6"></line>
          <line x1="17.6" y1="6.4" x2="19.4" y2="4.6"></line>
        </g>
        <path class="tt-moon" d="M20 14.5A8 8 0 0 1 9.5 4 7 7 0 1 0 20 14.5z"></path>
      </svg>
    </button>
    <details class="navmenu">
      <summary aria-label="Open navigation menu" title="Menu">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <line x1="3.5" y1="6" x2="20.5" y2="6"></line>
          <line x1="3.5" y1="12" x2="20.5" y2="12"></line>
          <line x1="3.5" y1="18" x2="20.5" y2="18"></line>
        </svg>
      </summary>
      <div class="navmenu-panel display">
        {links.map((l) => (
          <a href={l.href} aria-current={active === l.key ? 'page' : undefined}>{l.label}</a>
        ))}
      </div>
    </details>
  </div>
</nav>
